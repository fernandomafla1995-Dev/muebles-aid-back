{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "uid"
    },
    "statusOrder": {
      "type": "enumeration",
      "enum": [
        "pending",
        "procesing",
        "shipped",
        "delivered",
        "canceled"
      ]
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "customerName": {
      "type": "string",
      "required": true
    },
    "userEmail": {
      "type": "email",
      "required": true
    },
    "shippingAdress": {
      "type": "string",
      "default": "shippingAddress",
      "required": true
    },
    "items": {
      "type": "json"
    },
    "userId": {
      "type": "string"
    },
    "subtotal": {
      "type": "decimal"
    },
    "paymentintentId": {
      "type": "string"
    }
  }
}
